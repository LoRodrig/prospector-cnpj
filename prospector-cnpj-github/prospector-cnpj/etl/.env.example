# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commite o arquivo .env — ele está no .gitignore.

SUPABASE_HOST=aws-1-us-west-1.pooler.supabase.com
SUPABASE_PORT=6543
SUPABASE_DB=postgres
SUPABASE_USER=postgres
SUPABASE_PROJECT_REF=seu_project_ref
SUPABASE_PASSWORD=sua_senha_aqui

# Exigido pela política de uso do Nominatim (OpenStreetMap)
NOMINATIM_EMAIL=seu@email.com
